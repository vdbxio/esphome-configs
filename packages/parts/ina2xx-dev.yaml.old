# LEGACY — archived as ina2xx-dev.yaml.old; use packages/parts/ina2xx.yaml
# INA2XX 24.06-dev for PwrTool 500
# Voidbox Industries & Chloe Madison
# VDBX.io / @clomads
# CC-BY-SA 4.0
#
# AI disclaimer: Parts of this file were written or revised with AI assistance
#
# ina2xx: !include  {file: "packages/parts/ina2xx-dev.yaml", vars: {address: 0x40}}
#
# Single hardware SKU — Mode select changes sign handling on Bus Current/Power:
#   Battery: signed ± after offset; optional Invert (enable in HA)
#   Load / Charger: always positive (abs after offset); Invert ignored

select:
  - platform: template
    id: mode_select
    name: "Mode"
    optimistic: true
    restore_value: yes
    entity_category: config
    options:
      - "Battery Monitor - Bidirectional"
      - "DC Load - Unidirectional"
      - "DC Charger - Unidirectional"

switch:
  # Battery mode only — flip shunt sign without re-zeroing. Hidden until enabled in HA.
  - platform: template
    name: "Invert"
    id: invert
    restore_mode: RESTORE_DEFAULT_OFF
    optimistic: true
    entity_category: config
    disabled_by_default: true

button:
  - platform: template
    name: Offset - Set
    id: zero_offset
    entity_category: config
    icon: "mdi:circle"
    on_press:
      - logger.log: "Setting Offset"
      # Cumulative zero: add displayed current to stored offset (works on repeat presses).
      - number.set:
          id: offsetI_num
          value: !lambda 'return id(offsetI_num).state + id(rawI).state;'
      - logger.log:
          format: "Current - %.1f / Power - %.1f"
          args: [ 'id(offsetI_num).state', 'id(offsetI_num).state * id(rawV).state' ]
  - platform: template
    name: Offset - Clear
    id: clear_offset
    entity_category: config
    icon: "mdi:circle"
    on_press:
      - logger.log: "Clearing Offset"
      - number.set:
          id: offsetI_num
          value: 0.0
      - logger.log:
          format: "Current - %.1f / Power - %.1f"
          args: [ '0.0f', '0.0f' ]

number:
  # Offset in raw shunt amps (before sign/abs). Editable in HA; power follows I × V.
  - platform: template
    id: offsetI_num
    name: "Offset - Current"
    initial_value: 0.0
    min_value: -500.0
    max_value: 500.0
    step: 0.01
    optimistic: true
    restore_value: yes
    device_class: "current"
    unit_of_measurement: "A"
    entity_category: config
    on_value:
      - logger.log:
          format: "Current Offset set to %.1f"
          args: [ 'id(offsetI_num).state' ]

sensor:
  - platform: ina2xx_i2c
    id: ina23x
    address: ${address} # default: 0x40
    shunt_resistance: 0.00015 ohm
    model: INA238
    max_current: 500 A
    adc_range: 0
    adc_time: 4120 us
    adc_averaging: 128
    update_interval: 100ms
    # For 228/229:
    # energy: "Energy - Raw"
    # energy_joules: "Energy Joules - Raw"
    # charge: "Charge - Raw"
    # charge_coulombs: "Charge Coul - Raw"
    shunt_voltage:
      name: "Shunt - Voltage"
      device_class: "voltage"
      unit_of_measurement: "mV"
      accuracy_decimals: 3
      disabled_by_default: true
    bus_voltage:
      name: "Bus - Voltage"
      id: rawV
      device_class: "voltage"
      unit_of_measurement: "V"
      accuracy_decimals: 3
    current:
      name: "Bus - Current"
      id: rawI
      device_class: "current"
      unit_of_measurement: "A"
      accuracy_decimals: 2
      filters:
      # 1) Offset in hardware space, 2) then mode sign handling
      - lambda: !lambda 'return x - id(offsetI_num).state;'
      - lambda: !lambda |-
          if (id(mode_select).state == "Battery Monitor - Bidirectional") {
            if (id(invert).state) return {x * -1};
            return x;
          }
          // Load/Charger: magnitude only — abs corrects shunt orientation without Invert
          return x < 0.0f ? -x : x;
    power:
      name: "Bus - Power"
      id: rawP
      device_class: "power"
      unit_of_measurement: "W"
      accuracy_decimals: 2
      filters:
      # INA238 power register is unsigned; derive P from corrected I × V (same sign rules as current)
      - lambda: !lambda |-
          float i = id(rawI).raw_state - id(offsetI_num).state;
          if (id(mode_select).state == "Battery Monitor - Bidirectional") {
            if (id(invert).state) i *= -1;
            return i * id(rawV).state;
          }
          if (i < 0.0f) i = -i;
          return i * id(rawV).state;
    temperature:
      name: "Temperature - Shunt"
      accuracy_decimals: 2
